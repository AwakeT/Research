        </mxCell>

        <mxCell id="l4_task" value="任务结果展示&#xa;────────────&#xa;找物路线展示&#xa;找人房间定位&#xa;巡逻异常告警（低/中/高）&#xa;（由 L3 输出驱动）" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="2380" y="680" width="320" height="130" as="geometry" />
        </mxCell>

        <!-- L1 → L4 直驱 -->
        <mxCell id="e_l1_l4_room" value="Room Node → 总览 + 草图" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;strokeColor=#82b366;strokeWidth=1.5;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="l1_room" target="l4_overview" parent="1">
          <mxGeometry relative="1" as="geometry" />
